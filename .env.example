# Host path for the markdown corpus plus Dory runtime files.
DORY_DATA_ROOT=./data/corpus

# Bind HTTP to localhost by default. Use 0.0.0.0 only behind a trusted LAN,
# reverse proxy, VPN, or firewall.
DORY_HTTP_BIND=127.0.0.1
DORY_HTTP_PORT=8766

# Keep auth on for shared hosts. Generate bearer tokens with `uv run dory auth new <name>`.
DORY_ALLOW_NO_AUTH=false
DORY_WEB_PASSWORD=

# Gemini is required for the current HTTP/MCP/search/write runtime.
# OpenRouter is optional for dreaming, maintenance, and LLM-assisted retrieval.
DORY_GEMINI_API_KEY=
GOOGLE_API_KEY=
DORY_OPENROUTER_API_KEY=
OPENROUTER_API_KEY=

# Optional active-memory LLM. Use `off` for deterministic retrieval only,
# `local` for an OpenAI-compatible local/LAN endpoint, or `openrouter`.
DORY_ACTIVE_MEMORY_LLM_PROVIDER=off
DORY_ACTIVE_MEMORY_LLM_STAGES=compose
DORY_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
DORY_LOCAL_LLM_MODEL=qwen3.5:4b
DORY_LOCAL_LLM_TIMEOUT_SECONDS=5
DORY_LOCAL_LLM_MAX_TOKENS=512
DORY_LOCAL_LLM_API_KEY=
