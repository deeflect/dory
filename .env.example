# Host path for the markdown corpus plus Dory runtime files.
DORY_DATA_ROOT=./data/corpus

# Bind HTTP to localhost by default. Use 0.0.0.0 only behind a trusted LAN,
# reverse proxy, VPN, or firewall.
DORY_HTTP_BIND=127.0.0.1
DORY_HTTP_PORT=8766

# Optional Docker runtime DNS override. Leave blank unless containers cannot
# resolve external hosts from Docker's default bridge DNS.
DORY_DOCKER_DNS_SERVERS=

# Keep auth on for shared hosts. Generate bearer tokens with `uv run dory auth new <name>`.
DORY_ALLOW_NO_AUTH=false
DORY_WEB_PASSWORD=

# Gemini is the code default embedding provider for HTTP/MCP/search/write runtime.
# For Docker/LAN local embeddings, keep this file plus docker-compose.local.yml or
# set DORY_EMBEDDING_PROVIDER=local and the DORY_LOCAL_EMBEDDING_* values below.
# OpenRouter is optional for dreaming, maintenance, and LLM-assisted retrieval.
DORY_EMBEDDING_PROVIDER=gemini
DORY_EMBEDDING_MODEL=gemini-embedding-001
DORY_EMBEDDING_DIMENSIONS=768
DORY_EMBEDDING_BATCH_SIZE=100
DORY_GEMINI_API_KEY=
GOOGLE_API_KEY=
DORY_OPENROUTER_API_KEY=
OPENROUTER_API_KEY=
DORY_OPENROUTER_DREAM_MODEL=qwen/qwen3.6-plus
DORY_OPENROUTER_TIMEOUT_SECONDS=120

# Optional local/LAN OpenAI-compatible embedding provider.
# Set DORY_EMBEDDING_PROVIDER=local to use these.
DORY_LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:8000/v1
DORY_LOCAL_EMBEDDING_MODEL=qwen3-embed
DORY_LOCAL_EMBEDDING_QUERY_INSTRUCTION=Given a web search query, retrieve relevant passages that answer the query
DORY_LOCAL_EMBEDDING_TIMEOUT_SECONDS=30
DORY_LOCAL_EMBEDDING_API_KEY=

# Optional query reranker. Provider can be `openrouter` or `local`.
DORY_QUERY_RERANKER_ENABLED=false
DORY_QUERY_RERANKER_PROVIDER=openrouter
DORY_QUERY_RERANKER_CANDIDATE_LIMIT=40
DORY_LOCAL_RERANKER_BASE_URL=http://127.0.0.1:8000/v1
DORY_LOCAL_RERANKER_MODEL=qwen3-rerank
DORY_LOCAL_RERANKER_TIMEOUT_SECONDS=30
DORY_LOCAL_RERANKER_API_KEY=

# Optional local/LAN LLM. Active memory can use `off`, `local`, `openrouter`,
# or `auto`; dream/digest jobs can use `openrouter`, `local`, or `auto`.
DORY_ACTIVE_MEMORY_LLM_PROVIDER=off
DORY_ACTIVE_MEMORY_LLM_STAGES=compose
DORY_DREAM_LLM_PROVIDER=local
DORY_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
DORY_LOCAL_LLM_MODEL=qwen3.5:4b
DORY_LOCAL_LLM_TIMEOUT_SECONDS=5
DORY_LOCAL_LLM_MAX_TOKENS=512
DORY_LOCAL_LLM_API_KEY=
